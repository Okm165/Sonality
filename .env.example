# Copy to .env and fill in your values.
# Only variables that differ from defaults need to be set.

# LLM endpoint (OpenAI-compatible; set API_KEY empty for local servers)
SONALITY_BASE_URL=https://api.openai.com/v1
SONALITY_API_KEY=sk-...
SONALITY_MODEL=gpt-4.1-mini

# Embeddings (uses local FastEmbed bge-large-en-v1.5, 1024 dims)
# SONALITY_EMBEDDING_MAX_CHARS=4096    # max chars per embedding
# SONALITY_EMBEDDING_CACHE_SIZE=10000  # max cached query embeddings

# Qdrant (override if using non-standard port)
# SONALITY_QDRANT_URL=http://localhost:6333

# Optional tuning (all have sensible defaults — only override if needed)
# SONALITY_ESS_MODEL=                  # defaults to SONALITY_MODEL
# SONALITY_LLM_MAX_TOKENS=8192         # default for general LLM calls
# SONALITY_AGENT_TEMPERATURE=0.6       # temperature for conversational responses
# SONALITY_LLM_TIMEOUT=300             # seconds per HTTP request (5 min for 4096 tokens)
# SONALITY_ASYNC_TIMEOUT=1500          # seconds; 5x LLM_TIMEOUT for queued calls
# SONALITY_LOG_LEVEL=INFO

# Per-task LLM max_tokens (smaller budgets for structured JSON outputs)
# SONALITY_ESS_MAX_TOKENS=512                # ESS classification output
# SONALITY_STRUCTURED_JSON_MAX_TOKENS=256    # routing, sufficiency checks
# SONALITY_EXTRACTION_MAX_TOKENS=1024        # knowledge/feature extraction
# SONALITY_RERANK_MAX_TOKENS=512             # reranking candidate list

# === X (Twitter) Feed ===
X_BEARER_TOKEN=
# X_FEED_THROTTLE=2                                # seconds between /ingest calls
# X_FEED_MAX_RESULTS=10                            # posts per query page (10-100)
# X_FEED_MAX_PAGES=1                               # pagination depth per query
# X_FEED_SORT_ORDER=relevancy                      # relevancy | recency
# X_FEED_QUERIES=                                  # comma-separated query tags (empty = all)

# === Chat Module ===

# Telegram Bot (get token from @BotFather)
CHAT_TELEGRAM_TOKEN=

# Service URLs
CHAT_SONALITY_URL=http://localhost:8000
CHAT_SPEACHES_URL=http://localhost:8001

# === STT (Speech-to-Text) ===
# CHAT_STT_MODEL=Systran/faster-distil-whisper-large-v3
# CHAT_STT_LANGUAGE=en
# CHAT_STT_TIMEOUT=60.0

# === TTS (Text-to-Speech) ===
# CHAT_TTS_MODEL=speaches-ai/Kokoro-82M-v1.0-ONNX
# CHAT_TTS_VOICE=af_heart
# CHAT_TTS_SPEED=1.0
# CHAT_TTS_TIMEOUT=180.0
# CHAT_TTS_MAX_LENGTH=4096  # max chars per TTS request (API limit)
# CHAT_TTS_FORMAT=mp3       # Speaches supports: mp3, wav (NOT opus/aac)

# === TTS Optimization (LLM rewrite for natural speech) ===
# Enabled by default for voice message responses; text messages use original
# CHAT_TTS_OPTIMIZE=true                           # enable/disable optimization
# CHAT_TTS_OPTIMIZE_BASE_URL=                      # defaults to SONALITY_BASE_URL
# CHAT_TTS_OPTIMIZE_API_KEY=                       # defaults to SONALITY_API_KEY
# CHAT_TTS_OPTIMIZE_MODEL=                         # defaults to SONALITY_MODEL
# CHAT_TTS_OPTIMIZE_MAX_TOKENS=8192
# CHAT_TTS_OPTIMIZE_TEMPERATURE=0.3                # low temp for faithful rewriting
# CHAT_TTS_OPTIMIZE_TIMEOUT=60.0

# General
# CHAT_HTTP_TIMEOUT=512.0
# CHAT_LOG_LEVEL=DEBUG
