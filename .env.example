# Required
SONALITY_API_KEY=your-provider-api-key
SONALITY_API_VARIANT=anthropic

# API variant controls the Anthropic-compatible endpoint:
# - anthropic  -> https://api.anthropic.com
# - openrouter -> https://openrouter.ai/api

# Optional — override models
# SONALITY_MODEL=<main-model-id>
# Using a different model for ESS reduces self-judge bias (up to 50pp shift
# when the same model generates the response AND evaluates argument quality).
# See docs/model-considerations.md for guidance.
# SONALITY_ESS_MODEL=<separate-ess-model-id>

# Example OpenRouter model IDs:
# SONALITY_MODEL=anthropic/claude-sonnet-4
# SONALITY_ESS_MODEL=anthropic/claude-3.7-sonnet

# Optional — OpenRouter provider policy (only for SONALITY_API_VARIANT=openrouter)
# SONALITY_OPENROUTER_PROVIDER_ORDER=google-vertex,amazon-bedrock
# SONALITY_OPENROUTER_ALLOW_FALLBACKS=true
# SONALITY_OPENROUTER_FORCE_ZDR=true
# SONALITY_OPENROUTER_DATA_COLLECTION=deny

# Optional — tune behavior
# SONALITY_ESS_THRESHOLD=0.3
# SONALITY_BOOTSTRAP_DAMPENING_UNTIL=10
# SONALITY_OPINION_COOLING_PERIOD=3
# SONALITY_SEMANTIC_RETRIEVAL_COUNT=2
# SONALITY_EPISODIC_RETRIEVAL_COUNT=3
# SONALITY_LOG_LEVEL=INFO
