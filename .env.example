# Copy to .env and fill in your values.
# Only variables that differ from defaults need to be set.

# LLM endpoint (OpenAI-compatible; set API_KEY empty for local servers)
SONALITY_BASE_URL=https://api.openai.com/v1
SONALITY_API_KEY=sk-...

# === Model Tiers ===
# Four tiers from fastest to slowest — each handles a different cognitive load.
# All default to SONALITY_MODEL if not set. Override per-tier for speed/quality.
#
# FAST:       routing, boundary detection, reranking, summarization, decomposition
# STRUCTURED: ESS classification, knowledge extraction (needs tool_choice support)
# AGENT:      main agentic loop with tool calling (needs tool_choice support)
# REASONING:  reflection, synthesis, forgetting, quorum challenger (can be a thinking model)
#
# Example (Ollama local):
#   SONALITY_FAST_MODEL=gemma4:latest          # 8B — fast for simple decisions, no tools
#   SONALITY_STRUCTURED_MODEL=mistral-small:24b # 24B — tool calling + structured output
#   SONALITY_AGENT_MODEL=qwen3:32b             # 32B — tool calling + conversation
#   SONALITY_REASONING_MODEL=qwq:32b           # 32B — deep thinking model
#
# Tool-capable Ollama models: qwen3, qwen2.5, mistral-small, llama4, llama3.1, llama3.2
# Non-tool models (phi4, gemma4, deepseek-r1, qwq) work for FAST/REASONING only.
#
# REASONING_MODEL is used for deep analytical tasks: reflection consensus, research synthesis,
# forgetting decisions, and the quorum challenger role. A thinking model (qwq, deepseek-r1)
# works well here — these tasks benefit from chain-of-thought reasoning.

SONALITY_MODEL=gpt-4.1-mini
# SONALITY_FAST_MODEL=                  # defaults to SONALITY_MODEL
# SONALITY_STRUCTURED_MODEL=            # defaults to SONALITY_MODEL
# SONALITY_AGENT_MODEL=                 # defaults to SONALITY_MODEL
# SONALITY_REASONING_MODEL=             # defaults to SONALITY_MODEL

# Embeddings (uses local FastEmbed bge-large-en-v1.5, 1024 dims)
# SONALITY_EMBEDDING_MAX_CHARS=4096    # max chars per embedding
# SONALITY_EMBEDDING_CACHE_SIZE=10000  # max cached query embeddings

# Neo4j (Docker Compose defaults; override for remote or non-standard setup)
# SONALITY_NEO4J_URL=bolt://localhost:7687
# SONALITY_NEO4J_USER=neo4j
# SONALITY_NEO4J_PASSWORD=sonality_password

# Qdrant (override if using non-standard port)
# SONALITY_QDRANT_URL=http://localhost:6333

# Optional tuning (all have sensible defaults — only override if needed)
# SONALITY_LLM_MAX_TOKENS=16384       # max_tokens for all LLM calls (set high to never constrain)
# SONALITY_CHAT_INPUT_TOKEN_BUDGET=128000  # trim history if system+messages exceed this
# SONALITY_AGENT_TEMPERATURE=0.6       # temperature for conversational responses
# SONALITY_LLM_TIMEOUT=600             # seconds per HTTP request (10 min for local models)
# SONALITY_ASYNC_TIMEOUT=3000          # seconds; 5x LLM_TIMEOUT for queued calls
# SONALITY_LOG_LEVEL=INFO

# === Web Access (Firecrawl — self-hosted search + scrape via docker-compose) ===
# SONALITY_WEB_SEARCH_URL=http://localhost:3002  # Firecrawl API URL
# SONALITY_WEB_SEARCH_ENABLED=true               # master toggle for web access
# SONALITY_WEB_CACHE_TTL=14400                   # search cache TTL in seconds (4h)

# === HTTP API Authentication (optional) ===
# SONALITY_HTTP_API_KEY=                         # If set, all API requests must include this key

# === Feed Scripts ===
# SONALITY_URL=http://localhost:8000     # API base for feed.py / x_feed.py

# === X (Twitter) Feed ===
X_BEARER_TOKEN=
# X_FEED_THROTTLE=2                                # seconds between /ingest calls
# X_FEED_MAX_RESULTS=10                            # posts per query page (10-100)
# X_FEED_MAX_PAGES=1                               # pagination depth per query
# X_FEED_SORT_ORDER=relevancy                      # relevancy | recency
# X_FEED_QUERIES=                                  # comma-separated query tags (empty = all)

# === Speaches (STT/TTS) Docker Configuration ===
# Default runs on CPU. For GPU acceleration, set these:
# SPEACHES_IMAGE_TAG=latest              # use CUDA image (default: latest-cpu)
# SPEACHES_DEVICE=cuda                   # inference device (default: cpu)
# SPEACHES_COMPUTE_TYPE=float16          # precision (default: int8 for CPU)
# SPEACHES_CUDA_DEVICES=0               # GPU index (default: empty = CPU)
# SPEACHES_GPU_COUNT=1                   # GPUs to reserve (default: 0)

# === Chat Module ===

# Telegram Bot (get token from @BotFather)
CHAT_TELEGRAM_TOKEN=

# Service URLs
CHAT_SONALITY_URL=http://localhost:8000
CHAT_SPEACHES_URL=http://localhost:8001

# === STT (Speech-to-Text) ===
# CHAT_STT_MODEL=Systran/faster-distil-whisper-large-v3
# CHAT_STT_LANGUAGE=en
# CHAT_STT_TIMEOUT=60.0

# === TTS (Text-to-Speech) ===
# CHAT_TTS_MODEL=speaches-ai/Kokoro-82M-v1.0-ONNX
# CHAT_TTS_VOICE=af_heart
# CHAT_TTS_SPEED=1.0
# CHAT_TTS_TIMEOUT=180.0
# CHAT_TTS_MAX_LENGTH=4096  # max chars per TTS request (API limit)
# CHAT_TTS_FORMAT=mp3       # Speaches supports: mp3, wav (NOT opus/aac)

# === TTS Optimization (LLM rewrite for natural speech) ===
# Enabled by default for voice message responses; text messages use original
# CHAT_TTS_OPTIMIZE=true                           # enable/disable optimization
# CHAT_TTS_OPTIMIZE_BASE_URL=                      # defaults to SONALITY_BASE_URL
# CHAT_TTS_OPTIMIZE_API_KEY=                       # defaults to SONALITY_API_KEY
# CHAT_TTS_OPTIMIZE_MODEL=                         # defaults to SONALITY_MODEL
# CHAT_TTS_OPTIMIZE_MAX_TOKENS=8192
# CHAT_TTS_OPTIMIZE_TEMPERATURE=0.3                # low temp for faithful rewriting
# CHAT_TTS_OPTIMIZE_TIMEOUT=60.0

# General
# CHAT_MODEL_ID=sonality
# CHAT_HTTP_TIMEOUT=512.0
# CHAT_LOG_LEVEL=INFO
