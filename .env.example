# Copy to .env and fill in your values.
# Only variables that differ from defaults need to be set.

# === Core LLM Endpoint ===
SONALITY_BASE_URL=https://api.openai.com/v1
SONALITY_API_KEY=sk-...

# === Model Tiers ===
# Four tiers — each handles a different cognitive load.
# All default to SONALITY_MODEL if not set.
#
# FAST:       routing, boundary detection, reranking, summarization
# STRUCTURED: ESS classification, knowledge extraction, web query expansion (needs tool_choice)
# AGENT:      main agentic loop with tool calling (needs tool_choice)
# REASONING:  reflection, synthesis, forgetting, quorum challenger
SONALITY_MODEL=gpt-4.1-mini
# SONALITY_FAST_MODEL=
# SONALITY_STRUCTURED_MODEL=
# SONALITY_AGENT_MODEL=
# SONALITY_REASONING_MODEL=

# === Token Budgets ===
# LLM_MAX_TOKENS: single max_tokens passed to ALL LLM calls.
# CHAT_INPUT_TOKEN_BUDGET: trim conversation history when exceeded.
# For 8192 ctx: LLM_MAX_TOKENS=2700, CHAT_INPUT_TOKEN_BUDGET=5500
# SONALITY_LLM_MAX_TOKENS=8192
# SONALITY_CHAT_INPUT_TOKEN_BUDGET=128000

# === Agent Loop ===
# SONALITY_AGENT_LOOP_HARD_CEILING=12   # max iterations before forced stop
# SONALITY_AGENT_COMPRESS_THRESHOLD=12  # compress messages when count exceeds this
# SONALITY_AGENT_COMPRESS_KEEP_TAIL=4   # keep N most recent messages during compression
# SONALITY_AGENT_TEMPERATURE=0.6

# === Limits & Timeouts ===
# SONALITY_EPISODE_CONTENT_LIMIT=300    # chars per episode in prompts
# SONALITY_BELIEF_PROMPT_WINDOW=15      # max beliefs shown in prompts
# SONALITY_ESS_TIMEOUT=300              # ESS classification timeout (seconds)
# SONALITY_FORGETTING_CANDIDATE_LIMIT=10
# SONALITY_LLM_MAX_RETRIES=3
# SONALITY_LLM_BACKOFF_BASE=2.0
# SONALITY_LLM_CONCURRENCY=1           # max parallel LLM calls
# SONALITY_LLM_TIMEOUT=600             # seconds per HTTP request (10 min for local models)
# SONALITY_ASYNC_TIMEOUT=3000          # seconds; auto-derived as 5x LLM_TIMEOUT
# SONALITY_LOG_LEVEL=INFO

# === Retrieval ===
# SONALITY_RETRIEVAL_MAX_ITERATIONS=3
# SONALITY_RETRIEVAL_OVER_FETCH_FACTOR=3
# SONALITY_MAX_RERANK_CANDIDATES=50

# === Databases ===
# SONALITY_NEO4J_URL=bolt://localhost:7687
# SONALITY_NEO4J_USER=neo4j
# SONALITY_NEO4J_PASSWORD=sonality_password
# SONALITY_NEO4J_DATABASE=neo4j
# SONALITY_NEO4J_MAX_POOL_SIZE=50
# SONALITY_NEO4J_CONNECTION_TIMEOUT=30.0
# SONALITY_QDRANT_URL=http://localhost:6333

# === Embedding (local FastEmbed bge-large-en-v1.5, 1024 dims) ===
# SONALITY_EMBEDDING_MAX_CHARS=4096
# SONALITY_EMBEDDING_CACHE_SIZE=10000
# SONALITY_QDRANT_SEARCH_EF=128
# SONALITY_QDRANT_RESCORE=true

# === Web Access (delegated to Fathom research service) ===
# SONALITY_FATHOM_URL=http://localhost:8010
# SONALITY_WEB_SEARCH_ENABLED=true
# SONALITY_REFLECTION_WEB_QUERIES=3

# === HTTP API Authentication (optional) ===
# SONALITY_HTTP_API_KEY=

# === Feed Scripts ===
# SONALITY_URL=http://localhost:8000     # API base for feed.py / x_feed.py

# === X (Twitter) Feed ===
X_BEARER_TOKEN=
# X_FEED_THROTTLE=2                                # seconds between /ingest calls
# X_FEED_MAX_RESULTS=10                            # posts per query page (10-100)
# X_FEED_MAX_PAGES=1                               # pagination depth per query
# X_FEED_SORT_ORDER=relevancy                      # relevancy | recency
# X_FEED_QUERIES=                                  # comma-separated query tags (empty = all)

# === Speaches (STT/TTS) Docker Configuration ===
# Default runs on CPU. For GPU acceleration, set these:
# SPEACHES_IMAGE_TAG=latest              # use CUDA image (default: latest-cpu)
# SPEACHES_DEVICE=cuda                   # inference device (default: cpu)
# SPEACHES_COMPUTE_TYPE=float16          # precision (default: int8 for CPU)
# SPEACHES_CUDA_DEVICES=0               # GPU index (default: empty = CPU)
# SPEACHES_GPU_COUNT=1                   # GPUs to reserve (default: 0)

# === Chat Module ===

# Telegram Bot (get token from @BotFather)
CHAT_TELEGRAM_TOKEN=

# Service URLs
CHAT_SONALITY_URL=http://localhost:8000
CHAT_SPEACHES_URL=http://localhost:8020

# === STT (Speech-to-Text) ===
# CHAT_STT_MODEL=Systran/faster-distil-whisper-large-v3
# CHAT_STT_LANGUAGE=en
# CHAT_STT_TIMEOUT=60.0

# === TTS (Text-to-Speech) ===
# CHAT_TTS_MODEL=speaches-ai/Kokoro-82M-v1.0-ONNX
# CHAT_TTS_VOICE=af_heart
# CHAT_TTS_SPEED=1.0
# CHAT_TTS_TIMEOUT=180.0
# CHAT_TTS_MAX_LENGTH=4096  # max chars per TTS request (API limit)
# CHAT_TTS_FORMAT=mp3       # Speaches supports: mp3, wav (NOT opus/aac)

# === TTS Optimization (LLM rewrite for natural speech) ===
# Enabled by default for voice message responses; text messages use original
# CHAT_TTS_OPTIMIZE=true                           # enable/disable optimization
# CHAT_TTS_OPTIMIZE_BASE_URL=                      # defaults to SONALITY_BASE_URL
# CHAT_TTS_OPTIMIZE_API_KEY=                       # defaults to SONALITY_API_KEY
# CHAT_TTS_OPTIMIZE_MODEL=                         # defaults to SONALITY_MODEL
# CHAT_TTS_OPTIMIZE_MAX_TOKENS=8192
# CHAT_TTS_OPTIMIZE_TEMPERATURE=0.3                # low temp for faithful rewriting
# CHAT_TTS_OPTIMIZE_TIMEOUT=60.0

# General
# CHAT_MODEL_ID=sonality
# CHAT_HTTP_TIMEOUT=512.0
# CHAT_LOG_LEVEL=INFO

# =============================================================================
# Fathom — Autonomous Web Research Agent
# =============================================================================
# LLM: inherits SONALITY_BASE_URL / SONALITY_API_KEY / SONALITY_MODEL
# automatically. Override with FATHOM_* only if you need a separate config.
# Neo4j: shared instance with Sonality (separate node labels).

# === Research Session ===
# FATHOM_N=4                    # pages fetched per round (Playwright batch)
# FATHOM_MAX_PAGES=80           # hard stop — total pages per session
# FATHOM_SEARCH_CONCURRENCY=8   # parallel DDGS searches

# === LLM Overrides (only if different from Sonality) ===
# FATHOM_BASE_URL=
# FATHOM_API_KEY=
# FATHOM_MODEL=
# FATHOM_LLM_MAX_TOKENS=8192

# === Neo4j Overrides (only if different from defaults) ===
# FATHOM_NEO4J_URL=bolt://localhost:7687
# FATHOM_NEO4J_PASSWORD=sonality_password

# === Logging ===
# FATHOM_LOG_LEVEL=INFO
